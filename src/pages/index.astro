---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { terminalCut } from '../lib/transitions';

const artifacts = [
	{ title: 'Webflow University', url: 'https://university.webflow.com' },
	{ title: 'Lunar Rescue', url: 'https://lunar-rescue.com' },
	{ title: 'Random Word Device', url: 'https://apps.apple.com/us/app/random-word-device/id6762091662' },
	{ title: 'Flow To-go', url: 'https://flow-togo.com' },
	{ title: 'Finsweet Components', url: 'https://finsweet.com/components' },
	{ title: 'Asset Bae', url: 'https://webflow.com/apps/detail/asset-bae' },
	{ title: 'MP History', url: 'https://mphistory.org' },
];

const posts = (await getCollection('blog')).sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<Layout title="Keegan Leary — Designer + Builder">
	<aside class="column-left" slot="left" transition:animate={terminalCut}>
		<section aria-labelledby="operator-title">
			<h2 id="operator-title">About the operator</h2>
			<p class="bio">
				I design, build, and ship unusual software at speeds that make project managers visibly
				nervous.
			</p>
		</section>

		<nav class="artifacts" aria-labelledby="artifacts-title">
			<h3 id="artifacts-title">Deployed artifacts</h3>
			<ol>
				{artifacts.map((artifact, index) => (
					<li id={`artifact-${artifact.title.toLowerCase().replaceAll(' ', '-')}`}>
						<a href={artifact.url} target="_blank" rel="noopener noreferrer">
							<span>{String(index + 1).padStart(2, '0')}</span>
							{artifact.title}
						</a>
					</li>
				))}
			</ol>
		</nav>

		<a class="field-notes" href="#postmortems">Field notes <span>→</span></a>
	</aside>

	<section
		class="column-main postmortems"
		id="postmortems"
		slot="main"
		aria-labelledby="postmortems-title"
		transition:animate={terminalCut}
	>
		<div class="post-row post-header" aria-hidden="true">
			<span>Date</span>
			<span id="postmortems-title">Postmortems without the mortem</span>
			<span>Topic</span>
			<span>Read</span>
			<span>State</span>
		</div>

		{posts.map((post) => (
			<a class="post-row" href={`/blog/${post.id}`}>
				<time transition:name={`post-date-${post.id}`}>{post.data.date}</time>
				<strong transition:name={`post-title-${post.id}`}>{post.data.title}</strong>
				<span transition:name={`post-topic-${post.id}`}>{post.data.topic}</span>
				<span transition:name={`post-read-${post.id}`}>{post.data.read}</span>
				<span transition:name={`post-state-${post.id}`} class:list={{ new: post.data.state === 'New' }}>
					{post.data.state}
				</span>
			</a>
		))}
	</section>
</Layout>
